{
  "entities": {
    "SiteContent": {
      "title": "Site Content",
      "description": "General site-wide content and settings",
      "type": "object",
      "properties": {
        "home": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "slogan": { "type": "string" },
            "bgImage": { "type": "string" },
            "logo": { "type": "string" }
          }
        },
        "about": {
          "type": "object",
          "properties": {
            "history": { "type": "string" },
            "member1": { "$ref": "Member" },
            "member2": { "$ref": "Member" }
          }
        },
        "contact": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "address": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "youtube": { "type": "string" },
            "instagram": { "type": "string" },
            "naverBlog": { "type": "string" },
            "naverPlace": { "type": "string" }
          }
        }
      }
    },
    "Member": {
      "title": "Team Member",
      "description": "Information about a magic team member",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "bio": { "type": "string" },
        "links": { "type": "array", "items": { "type": "string" } },
        "videoUrl": { "type": "string" },
        "image": { "type": "string" },
        "order": { "type": "integer" }
      }
    },
    "Performance": {
      "title": "Performance Item",
      "description": "A specific performance with image, title and description",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "order": { "type": "integer" }
      }
    },
    "GalleryItem": {
      "title": "Gallery Image",
      "description": "An image in the activity gallery",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "integer" }
      }
    },
    "Partner": {
      "title": "Network Partner",
      "description": "A partner or collaboration company",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "integer" }
      }
    },
    "User": {
      "title": "User Profile",
      "description": "User account information and role",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/siteContent/main": {
      "schema": "SiteContent",
      "description": "Main site content"
    },
    "/performances/{id}": {
      "schema": "Performance",
      "description": "List of magic fields and repertoires"
    },
    "/gallery/{id}": {
      "schema": "GalleryItem",
      "description": "Activity photos"
    },
    "/partners/{id}": {
      "schema": "Partner",
      "description": "Collaboration network"
    },
    "/members/{id}": {
      "schema": "Member",
      "description": "Team members list"
    },
    "/users/{id}": {
      "schema": "User",
      "description": "User profiles and roles"
    }
  }
}
